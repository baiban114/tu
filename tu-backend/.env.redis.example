# Copy to .env.redis and adjust if ports conflict with existing containers.
# Used only by docker-compose.redis.yml (standalone Redis Cluster stack).

# Address announced to clients is resolved at runtime from host.docker.internal (see scripts/redis-cluster-node.sh).

# Client ports (cluster bus ports = client port + 10000).
REDIS_NODE_1_PORT=6379
REDIS_NODE_1_BUS_PORT=16379
REDIS_NODE_2_PORT=6380
REDIS_NODE_2_BUS_PORT=16380
REDIS_NODE_3_PORT=6381
REDIS_NODE_3_BUS_PORT=16381
REDIS_NODE_4_PORT=6382
REDIS_NODE_4_BUS_PORT=16382
REDIS_NODE_5_PORT=6383
REDIS_NODE_5_BUS_PORT=16383
REDIS_NODE_6_PORT=6384
REDIS_NODE_6_BUS_PORT=16384

# Spring / Lettuce example (cluster mode):
# SPRING_DATA_REDIS_CLUSTER_NODES=127.0.0.1:6379,127.0.0.1:6380,127.0.0.1:6381,127.0.0.1:6382,127.0.0.1:6383,127.0.0.1:6384
